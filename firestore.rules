rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone who is logged in to manage the hub
    function isLoggedIn() {
      return request.auth != null;
    }

    // Products collection: Anyone can read, any logged-in user can manage
    match /products/{productId} {
      allow read: if true;
      allow write: if isLoggedIn();
    }
    
    // Admin settings and users: Any logged-in user can access
    match /admins/{adminId} {
      allow read, write: if isLoggedIn();
    }

    // Default deny for all other collections to prevent unauthorized access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}