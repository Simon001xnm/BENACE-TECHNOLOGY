rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read products
    match /products/{productId} {
      allow read: if true;
      // In "test mode", allow any authenticated user to write.
      // For production, you would restrict this to specific admin UIDs.
      allow write: if request.auth != null;
    }
    
    // Allow users to manage their own admin profiles
    match /admins/{adminId} {
      allow read, write: if request.auth != null && request.auth.uid == adminId;
    }

    // Default deny for all other collections to maintain security
    match /{document=**} {
      allow read, write: if false;
    }
  }
}