rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Authorized Admin Email
    function isGodAdmin() {
      return request.auth != null && request.auth.token.email == "benacetechnologies@gmail.com";
    }

    // Products rules: Public read access, only God Admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isGodAdmin();
    }
    
    // Admin settings: Only God Admin can access
    match /admins/{adminId} {
      allow read, write: if isGodAdmin();
    }

    // Default deny for all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}