rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to see product images
    // Allow any logged-in user to upload or delete product images
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default deny for everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}